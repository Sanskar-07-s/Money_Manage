#!/usr/bin/env sh

echo "Running secret scan on staged files..."
staged_files="$(git diff --cached --name-only --diff-filter=ACMRTUXB)"

if [ -z "$staged_files" ]; then
  exit 0
fi

SECRET_SCAN_FILES="$staged_files" node scripts/secret-scan.js --staged
status=$?

if [ $status -ne 0 ]; then
  echo "Commit blocked by secret scanner."
  exit $status
fi

exit 0
